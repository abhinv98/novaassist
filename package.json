{
  "name": "nova-assist",
  "version": "1.0.7",
  "description": "Voice-first AI desktop agent for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "publish": "electron-builder --mac --publish always"
  },
  "keywords": ["voice", "ai", "desktop-agent", "macos", "accessibility", "amazon-nova"],
  "author": "Abhinav Rai",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.novaassist.app",
    "productName": "NovaAssist",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "NovaAssist needs microphone access to hear your voice commands.",
        "NSAccessibilityUsageDescription": "NovaAssist needs Accessibility access to detect UI elements and control mouse/keyboard.",
        "NSScreenCaptureUsageDescription": "NovaAssist needs Screen Recording access to capture screenshots for AI screen analysis."
      }
    },
    "dmg": {
      "title": "NovaAssist",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "src/**/*",
      "main.js",
      "preload.js",
      "test-cli.js",
      "requirements.txt",
      "package.json",
      "!src/python/__pycache__/**"
    ],
    "extraResources": [
      {
        "from": "src/python",
        "to": "python",
        "filter": ["**/*.py"]
      },
      {
        "from": "requirements.txt",
        "to": "requirements.txt"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "abhinv98",
      "repo": "novaassist"
    }
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1009.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
